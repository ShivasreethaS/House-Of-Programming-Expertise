class Solution {
    public int twoCitySchedCost(int[][] costs) {
        int n=costs.length;
        //sort:asc based on the diff in costs
        Arrays.sort(costs,(a,b)->(a[0]-a[1])-(b[0]-b[1]));
        //now add 1st val(a cost) for 1st n/2 cities
        int res=0;
        for(int i=0;i<n/2;i++){
            res+=costs[i][0];
        }//now add 2nd val(b cost) for next n/2 cities
        for(int i=n/2;i<n;i++){
            res+=costs[i][1];
        }
        return res;
    }
}
