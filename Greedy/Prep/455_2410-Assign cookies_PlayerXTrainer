class Solution {
    public int findContentChildren(int[] g, int[] s) {
        int n,m,i=0,j=0;
        //find length
        n=g.length;
        m=s.length;
        //sort them so that we can match smallest greed with smallest cookie size
        Arrays.sort(g);
        Arrays.sort(s);
        //traverse till end
        while(i<n && j<m){
            //when greed <= cookie size: move to next greed and cookie size
            if(g[i]<=s[j]){
                i++;
                j++;
            }//else go to next cookie size to know if it matches the curr greed
            else{
                j++;
            }
        }//return total child(greed) satisfied
        return i;
    }
}

class Solution {
    public int matchPlayersAndTrainers(int[] players, int[] trainers) {
        Arrays.sort(players);
        Arrays.sort(trainers);
        int i=0,j=0;
        while(i<players.length && j<trainers.length){
            if(players[i]<=trainers[j]){
                i++;
                j++;
            }else{
                j++;
            }
        }return i;
    }
}
