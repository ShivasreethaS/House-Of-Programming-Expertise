class Solution {
    public List<String> generateParenthesis(int n) {
        List<String> l=new ArrayList<>();
        gen(l,"",0,0,n);
        return l;
    }
    public void gen(List<String>l,String s,int oc,int cc,int n){
        if(n*2==s.length()){
            l.add(s);
            return;
        }
        if(oc<n){
            gen(l,s+"(",oc+1,cc,n);
        }
        if(cc<oc){
            gen(l,s+")",oc,cc+1,n);
        }
    }
}
