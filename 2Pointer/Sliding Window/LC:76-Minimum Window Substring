class Solution {
    public String minWindow(String s, String t) {
       //when str is smaller than target then empty
       if(s.length()<t.length()){
        return "";
       }
       //count stores total elements in target
       int count=t.length();
       //stores the char with need count(freq)
       int needFreq[]=new int[128];
       for(int i=0;i<t.length();i++){
        needFreq[t.charAt(i)]++;
       }
       //start stores the minlen's start, left for front movinf
       int start=0,left=0,minLen=Integer.MAX_VALUE;
       //check all char from s: if needed then freq will be >0 then decrement it as we got the char
       for(int right=0;right<s.length();right++){
        if(needFreq[s.charAt(right)]>0){
            count--;
        }
        //freq of all are decremented as we increment freq for all char without "checking"
        needFreq[s.charAt(right)]--;
        //when count is 0 then we got all req chars{may contain some unwanted char infront} so check minLen
        while(count==0){
            if(minLen>right-left+1){
                minLen=right-left+1;
                start=left;
            }
            //we are removing the left char so need is increased
            needFreq[s.charAt(left)]++;
            //if that's a target need then count is also increment
            if(needFreq[s.charAt(left)]>0){
                count++;
            }
            left++;
        }
       }
       //if no such substr then empty else that substr
       return minLen==Integer.MAX_VALUE?"":s.substring(start,start + minLen);
    }
}
