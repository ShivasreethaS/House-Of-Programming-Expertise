i/p: nums=[1,2,3,4,5],k=3(number of elements that should be in the subarray)
o/p:maximum avg for a subarray of size,k "3.5"
class Solution {
    public double findMaxAverage(int[] nums, int k) {
        double maxSum=0,sum=0;
        //find sum of 1st k elements
        for(int i=0;i<k;i++){
            sum+=nums[i];
        }
        //store the sum in maxSum
        maxSum=sum;
        //rear for moving to next element during sum & front is for removing the prev front element during sum
        int rear=k,front=0;
        while(rear<nums.length){
            sum=sum-nums[front]+nums[rear];
            rear++;
            front++;
            maxSum=Math.max(sum,maxSum);
        }
        return maxSum/k;
    }
}
