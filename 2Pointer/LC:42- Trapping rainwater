class Solution {
    public int trap(int[] height) {
        int n=height.length;
        int leftMax[]=new int[n];
        int rightMax[]=new int[n];
        leftMax[0]=height[0];
        rightMax[n-1]=height[n-1];
        int total=0;
        //to get the maxs from the left side.
        for(int i=1;i<n;i++){
            leftMax[i]=Math.max(leftMax[i-1],height[i]);
        }
        //to get the maxs from right side
        for(int i=n-2;i>=0;i--){
            rightMax[i]=Math.max(rightMax[i+1],height[i]);
        }
        for(int i=0;i<n;i++){
            //total= old total + get the min wall height(till that only water can be stored) and minus the height[i] from the available space if any blocking height exists at that place
            total=total+Math.min(rightMax[i],leftMax[i])-height[i];
        }
        return total;
    }
}
