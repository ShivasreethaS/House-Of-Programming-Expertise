import java.util.*;

public class Main {
    public static void main(String[] args) {
      Scanner sc=new Scanner(System.in);
      int n=sc.nextInt();
      int r=0;
      if(n==rev(n,r)){
        System.out.println("Palindrome number");
      }
      else{
        System.out.println("No");
      }
    }
    public static int rev(int n,int r){
      if(n==0){
        return r;
      }
      r=(r*10)+(n%10);
      return rev(n/10,r);
    }
}
